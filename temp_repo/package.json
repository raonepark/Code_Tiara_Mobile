{
    "name": "code-tiara",
    "productName": "Code Tiara",
    "description": "A powerful dashboard for productivity",
    "author": "Lumora",
    "version": "1.7.4",
    "private": true,
    "dependencies": {
        "firebase": "^12.13.0",
        "i18next": "^26.2.0",
        "i18next-browser-languagedetector": "^8.2.1",
        "react-i18next": "^17.0.8"
    },
    "main": "public/main.js",
    "homepage": "./",
    "scripts": {
        "start": "react-scripts start",
        "build": "react-scripts build",
        "test": "react-scripts test",
        "eject": "react-scripts eject",
        "electron:dev": "concurrently \"cross-env BROWSER=none npm start\" \"wait-on http://localhost:3000 && \\\"./node_modules/electron/dist/electron.exe\\\" .\"",
        "electron:build": "npm run build && electron-builder -w --config tiara.setup.js"
    },
    "eslintConfig": {
        "extends": [
            "react-app",
            "react-app/jest"
        ]
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "devDependencies": {
        "@hello-pangea/dnd": "^18.0.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.1",
        "@testing-library/user-event": "^13.5.0",
        "autoprefixer": "^10.4.23",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^33.2.1",
        "electron-builder": "^26.4.0",
        "electron-is-dev": "^3.0.1",
        "lucide-react": "^0.562.0",
        "postcss": "^8.5.6",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-scripts": "5.0.1",
        "tailwindcss": "^3.4.19",
        "wait-on": "^9.0.3",
        "web-vitals": "^2.1.4"
    }
}
